# Monorepo-wide env. Copy to `.env.local` (gitignored) and fill in.
#
# Apps EXTEND this file by default: values here are inherited by apps/web and
# apps/mobile via scripts/with-env.mjs. An app's own .env / .env.local overrides
# these. To make an app ignore the root, set `EXTEND_ROOT_ENV=false` in that app.

# Convex deployment URL (from `cd packages/backend && npx convex dev`).
# Shared here so both apps read the same backend; override per-app if needed.
NEXT_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_URL=
