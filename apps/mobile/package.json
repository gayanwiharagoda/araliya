{
  "name": "@domus/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/with-env.mjs expo start",
    "android": "node ../../scripts/with-env.mjs expo start --android",
    "ios": "node ../../scripts/with-env.mjs expo start --ios",
    "web": "node ../../scripts/with-env.mjs expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "expo": "~56.0.12",
    "expo-router": "~56.2.11",
    "expo-linking": "~56.0.14",
    "expo-constants": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-screens": "~4.25.2",
    "react-native-safe-area-context": "~5.8.0",
    "convex": "^1.42.0",
    "@domus/backend": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react-dom": "19.2.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
