{
  "name": "domus-os",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "turbo typecheck lint && prettier --check . && turbo test",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "prettier": "^3.8.4",
    "eslint": "^9",
    "@eslint/js": "^9",
    "typescript-eslint": "^8.62.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx,mts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
