# Convex deployment (set by `npx convex dev`)
CONVEX_DEPLOYMENT=

# Public URL of the site, used by Convex Auth for provider callbacks.
SITE_URL=http://localhost:3000

# Convex Auth JWT signing keys — generate with `npx @convex-dev/auth`.
# JWKS is public; JWT_PRIVATE_KEY is secret. Do not commit real values.
JWKS=
JWT_PRIVATE_KEY=
